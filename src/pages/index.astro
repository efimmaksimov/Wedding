---
import IntroEnvelope from '../components/IntroEnvelope.astro';
import NavBar from '../components/NavBar.astro';
import Hero from '../components/Hero.astro';
import CalendarBlock from '../components/CalendarBlock.astro';
import VenueBlock from '../components/VenueBlock.astro';
import ScheduleBlock from '../components/ScheduleBlock.astro';
import DressCodeBlock from '../components/DressCodeBlock.astro';
import DressCarousel from '../components/DressCarousel.astro';
import ImportantInfo from '../components/ImportantInfo.astro';
import ContactsBlock from '../components/ContactsBlock.astro';
import data from '../data/wedding.json';
import '../styles/global.css';
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Свадьба {data.couple.bride} и {data.couple.groom}</title>
  </head>
  <body>
    <IntroEnvelope />
    <NavBar />
    <main class="container">
      <Hero couple={data.couple} invitationText={data.invitationText} heroPhoto={data.heroPhoto} />
      <CalendarBlock date={data.date} arrivalTime={data.arrivalTime} />
      <VenueBlock venue={data.venue} />
      <ScheduleBlock schedule={data.schedule} />
      <DressCodeBlock palette={data.palette} />
      <DressCarousel dressRefs={data.dressRefs} />
      <ImportantInfo important={data.important} formLink={data.formLink} />
      <ContactsBlock organizer={data.organizer} />
    </main>
  </body>
</html>
